# AI Career Coach - Backend Environment Configuration

# App Settings
DEBUG=false
APP_NAME="AI Career Coach"

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Database
DATABASE_URL="sqlite:///./app.db"

# Report Generation Model (External API - e.g., OpenAI, Anthropic)
# This is used for the comprehensive report generation
REPORT_MODEL_PROVIDER="openai"  # Options: openai, anthropic, ollama
REPORT_MODEL_NAME="gpt-4o-mini"
OPENAI_API_KEY="your-openai-api-key-here"
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# Chatbot Model (Local/Free option for zero cost)
# Default is Ollama for zero-cost local inference
CHATBOT_PROVIDER="ollama"  # Options: ollama, openai, anthropic, huggingface
CHATBOT_MODEL_NAME="llama3.2"
OLLAMA_BASE_URL="http://localhost:11434"

# Optional: Hugging Face (for alternative free cloud option)
HUGGINGFACE_API_KEY="your-hf-api-key-here"

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Generation Settings
MAX_REPORT_TOKENS=4000
REPORT_TEMPERATURE=0.3
MAX_CHAT_TOKENS=2000
CHAT_TEMPERATURE=0.7