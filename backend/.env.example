# AI Career Coach - Backend Environment Configuration
# ============================================
# DEFAULT: Groq API (FREE, no credit card required)
# Get your FREE API key at: https://console.groq.com/
# Free tier: 30 RPM, 14,400 RPD, 500K tokens/day
# Report generation: ~10-30 seconds with Groq
# ============================================

# App Settings
DEBUG=false
APP_NAME="AI Career Coach"

# CORS Origins (comma-separated)
# Add your deployed frontend URL when deploying
BACKEND_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000"

# Database
DATABASE_URL="sqlite:///./app.db"

# ============================================
# AI MODEL CONFIGURATION
# ============================================

# --- REPORT GENERATION ---
# RECOMMENDED: Groq (FREE, ultra-fast ~10-30 seconds)
# Get FREE API key: https://console.groq.com/
REPORT_MODEL_PROVIDER="groq"
REPORT_MODEL_NAME="llama-3.1-8b-instant"  # Fast, good quality
GROQ_API_KEY="your_groq_api_key_here"  # Get FREE at https://console.groq.com/

# --- ALTERNATIVE: Ollama (local, free, no API key, slower ~2-4 min) ---
# REPORT_MODEL_PROVIDER="ollama"
# REPORT_MODEL_NAME="llama3.1:latest"
# OLLAMA_BASE_URL="http://localhost:11434"

# --- CHATBOT ---
# Default: Ollama (free, local)
CHATBOT_PROVIDER="ollama"
CHATBOT_MODEL_NAME="llama3.2"

# --- Ollama Settings ---
OLLAMA_BASE_URL="http://localhost:11434"

# --- OPTIONAL: HuggingFace Free Inference ---
# Many models work without an API key (rate-limited)
# Set a key for higher limits: https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=""

# --- OPTIONAL: Paid APIs (NOT REQUIRED) ---
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB

# Generation Settings
MAX_REPORT_TOKENS=4000
REPORT_TEMPERATURE=0.3
MAX_CHAT_TOKENS=2000
CHAT_TEMPERATURE=0.7